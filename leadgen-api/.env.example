# Base de datos y Redis
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/leadgen
REDIS_URL=redis://redis:6379/0

# API Securiry
API_KEY=your_super_secret_api_key_for_n8n

# Instagram (JSON array)
IG_ACCOUNTS=[{"username":"your_ig_username","password":"your_ig_password"}]

# Logging
LOG_LEVEL=INFO

# Scheduler
JOB_MAX_MINUTES=28
JOB_TARGET_LEADS=1200
JOB_SCHEDULE_HOUR=3

# SMTP Verifier
SMTP_EHLO_DOMAIN=gmail.com

# Scraper/Classifier limits
MIN_SCORE_THRESHOLD=40
